# ============================================================
# GLPI Analytics — modelo de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# Este arquivo É versionado; .env NÃO é.
# ============================================================

# ------ Banco de dados (MariaDB / GLPI) ------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=glpi
DB_USER=glpi_readonly
DB_PASSWORD=your_password_here

# ------ Power BI Service (opcional — pipeline/powerbi_refresh.py) ------
# Registre um App no Azure AD com permissão Dataset.ReadWrite.All
# Docs: https://learn.microsoft.com/en-us/power-bi/developer/embedded/register-app
POWERBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_CLIENT_SECRET=your_client_secret_here
POWERBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POWERBI_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Intervalo de refresh em segundos (padrão: 300 = 5 min)
# Power BI Service limita a 8 refreshes/dia no plano gratuito; 48/dia no Pro
REFRESH_INTERVAL_SEC=300
